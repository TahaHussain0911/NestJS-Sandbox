<!DOCTYPE html>
<html>
  <body style="font-family: Arial; padding: 20px">
    <h2>Password Reset Request</h2>
    <p>Hey <%= name %>!. You requested to reset your password.</p>

    <p>
      Click the link below to continue:<br /><br />
      <a
        href="<%= url %>"
        style="
          background: #007bff;
          color: #fff;
          padding: 10px 15px;
          text-decoration: none;
          border-radius: 4px;
        "
      >
        Reset Password
      </a>
    </p>

    <p style="color: #888; font-size: 14px">
      If you didn't ask for this, you can safely ignore the email.
    </p>
  </body>
</html>
